# ====================================================================
# VIRUALIZATION & OPERATING SYSTEMS
# ====================================================================
# Block massive virtual disks and state files from virt-manager/QEMU
*.qcow2
*.img
*.vhd
*.vhdx
*.xml
*.state

# Block OS clutter and temporary files
.DS_Store
Thumbs.db
~$*.docx
~$*.xlsx
~$*.pptx

# ====================================================================
# CYBERSECURITY LAB EXCLUSIONS
# ====================================================================
# Block raw binary artifacts and full forensic packet captures
*.pcap
*.pcapng
*.evtx
*.log
*.audit
*.iso
*.vmdk
*.ova

# Block system memory dumps and master file tables
*.dmp
*.sys
*.mft
Memory.dmp

# Block vulnerable database dumps from DVWA
*.sql
*.sqlite

# ====================================================================
# SECRETS & CREDENTIALS (NEVER COMMIT)
# ====================================================================
.env
.env.*
*.pem
*.key
*.pub
*.cert
secrets.json
credentials.ini

# ====================================================================
# IDE & AUTOMATION SCRIPTING
# ====================================================================
.vscode/
.idea/
__pycache__/
*.py[cod]
.venv/
venv/
.ipynb_checkpoints/
